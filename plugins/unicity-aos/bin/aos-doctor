#!/usr/bin/env sh
# SessionStart bootstrap and health check for the Unicity AOS Codex plugin.
set -eu

MODE=human
while [ "$#" -gt 0 ]; do
  case "$1" in
    --format)
      MODE="${2:-human}"
      shift 2
      ;;
    --format=*)
      MODE="${1#--format=}"
      shift
      ;;
    *)
      shift
      ;;
  esac
done

if [ "$MODE" = hook ]; then
  cat >/dev/null 2>&1 || true
fi

if [ -z "${AOS_PLUGIN_ROOT:-}" ]; then
  AOS_PLUGIN_ROOT="${CODEX_PLUGIN_ROOT:-${PLUGIN_ROOT:-}}"
fi
if [ -z "$AOS_PLUGIN_ROOT" ]; then
  AOS_PLUGIN_ROOT="$(CDPATH= cd -- "$(dirname "$0")/.." 2>/dev/null && pwd -P)" \
    || AOS_PLUGIN_ROOT="$(dirname "$(dirname "$0")")"
fi
export AOS_PLUGIN_ROOT
BOOTSTRAP_ERROR=""
NUDGE_MSG=""

VERSION_FILE="$AOS_PLUGIN_ROOT/.aos-oracle-version"
[ -f "$VERSION_FILE" ] && [ ! -L "$VERSION_FILE" ] || {
  printf '%s\n' "Unicity AOS plugin snapshot has no Oracle release identity. Reinstall the Codex plugin."
  exit 0
}
ORACLE_VERSION=$(sed -n '1p' "$VERSION_FILE")
printf '%s\n' "$ORACLE_VERSION" | grep -Eq '^[0-9]+\.[0-9]+\.[0-9]+$' || {
  printf '%s\n' "Unicity AOS plugin snapshot has an invalid Oracle release identity. Reinstall the Codex plugin."
  exit 0
}

RESOLVE="$AOS_PLUGIN_ROOT/bin/lib-aos-resolve.sh"
if [ ! -f "$RESOLVE" ]; then
  RESOLVE="$(CDPATH= cd -- "$(dirname "$0")" 2>/dev/null && pwd -P)/lib-aos-resolve.sh"
fi
# shellcheck source=lib-aos-resolve.sh
. "$RESOLVE"
aos_enter_product_workspace || {
  emit "Unicity AOS could not enter its product runtime workspace."
  exit 0
}

json_escape() {
  printf '%s' "$1" \
    | sed -e 's/\\/\\\\/g' -e 's/"/\\"/g' \
    | awk 'NR>1{printf "\\n"} {printf "%s", $0}'
}

emit() {
  report="$1"
  if [ "$MODE" != hook ]; then
    printf '%s\n' "$report"
    return 0
  fi
  if command -v jq >/dev/null 2>&1; then
    if [ -n "$NUDGE_MSG" ]; then
      jq -n --arg ctx "$report" --arg msg "$NUDGE_MSG" \
        '{systemMessage:$msg,hookSpecificOutput:{hookEventName:"SessionStart",additionalContext:$ctx}}'
    else
      jq -n --arg ctx "$report" \
        '{hookSpecificOutput:{hookEventName:"SessionStart",additionalContext:$ctx}}'
    fi
  else
    if [ -n "$NUDGE_MSG" ]; then
      printf '{"systemMessage":"%s","hookSpecificOutput":{"hookEventName":"SessionStart","additionalContext":"%s"}}\n' \
        "$(json_escape "$NUDGE_MSG")" "$(json_escape "$report")"
    else
      printf '{"hookSpecificOutput":{"hookEventName":"SessionStart","additionalContext":"%s"}}\n' \
        "$(json_escape "$report")"
    fi
  fi
}

PRINCIPAL="${ASTRID_PRINCIPAL_ID:-codex-code}"
case "$PRINCIPAL" in
  ""|*[!A-Za-z0-9_-]*) PRINCIPAL=codex-code ;;
esac

pack_is_current() {
  pack="${AOS_HOME:-$HOME/.aos}/extensions/oracles/codex/Pack.lock"
  [ -r "$pack" ] && grep -Fqx "version = \"$ORACLE_VERSION\"" "$pack"
}

resolve_initial() {
  if [ "$MODE" = hook ]; then
    aos_resolve_apply 2>/dev/null
  else
    aos_resolve_apply
  fi
}

bootstrap_codex() {
  [ "$MODE" = hook ] || return 1
  launcher="$AOS_PLUGIN_ROOT/bin/aos-up"
  [ -x "$launcher" ] || return 1
  log="${TMPDIR:-/tmp}/aos-codex-bootstrap.$$.log"
  if AOS_HOST=codex "$launcher" codex ensure-principal >"$log" 2>&1; then
    rm -f "$log"
    aos_resolve_apply
    return $?
  fi
  BOOTSTRAP_ERROR="$(tail -n 1 "$log" 2>/dev/null || true)"
  rm -f "$log"
  return 1
}

if ! resolve_initial && ! bootstrap_codex; then
  emit "Unicity AOS is not installed, so this Codex session has no governed AOS tools.

Automatic setup could not complete${BOOTSTRAP_ERROR:+: $BOOTSTRAP_ERROR}.
Retry with:

    $AOS_PLUGIN_ROOT/bin/aos-install --host codex --yes

Then start a new Codex session."
  exit 0
fi

VERSION="$("$AOS" --version 2>/dev/null | head -n1 || true)"

if ! pack_is_current \
  || ! "$AOS" capsule show aos-mcp --agent "$PRINCIPAL" >/dev/null 2>&1
then
  if bootstrap_codex \
    && "$AOS" capsule show aos-mcp --agent "$PRINCIPAL" >/dev/null 2>&1
  then
    :
  else
  emit "Unicity AOS — Codex principal '$PRINCIPAL' is not provisioned for the oracle pack.

Automatic setup could not complete${BOOTSTRAP_ERROR:+: $BOOTSTRAP_ERROR}.
Retry with:

    $AOS_PLUGIN_ROOT/bin/aos-install --host codex --yes

Then start a new Codex session."
    exit 0
  fi
fi

STATUS="$("$AOS" status --json 2>/dev/null || true)"

if [ -n "$STATUS" ] \
  && printf '%s' "$STATUS" | grep -Eq '"state"[[:space:]]*:[[:space:]]*"running"'
then
  if ! printf '%s' "$STATUS" | grep -Eq '"loaded_capsules"[[:space:]]*:[[:space:]]*\[[^]]*"aos-mcp"'; then
    emit "Unicity AOS — Codex principal '$PRINCIPAL' is provisioned, but its broker is not loaded.

The runtime is reachable, but aos-mcp is absent from the live capsule set.
Stop and restart the product runtime once, then reconnect this MCP server:

    aos stop

The next AOS command starts the current signed fleet."
    exit 0
  fi

  if command -v jq >/dev/null 2>&1; then
    PIDLINE="PID $(printf '%s' "$STATUS" | jq -r '.pid // "unknown"' 2>/dev/null || printf unknown)"
    CAPCOUNT="Capsules: $(printf '%s' "$STATUS" | jq -r '.loaded_capsules | length' 2>/dev/null || printf unknown) loaded"
  else
    PIDLINE="PID $(printf '%s' "$STATUS" | sed -n 's/.*"pid"[[:space:]]*:[[:space:]]*\([0-9][0-9]*\).*/\1/p')"
    CAPCOUNT="Capsules: live inventory includes aos-mcp"
  fi
else
  PIDLINE="starts on MCP connect"
  CAPCOUNT="Capsules: aos-mcp provisioned"
fi

if [ -x "$AOS_PLUGIN_ROOT/bin/aos-update-check" ]; then
  NUDGE_MSG=$("$AOS_PLUGIN_ROOT/bin/aos-update-check" "$AOS" 2>/dev/null || true)
fi

emit "Unicity AOS is ready for this Codex session.

  Principal: $PRINCIPAL
  Version:   ${VERSION:-unknown}
  Runtime:   $PIDLINE
  $CAPCOUNT

Use the mcp__aos__* tools for governed operations. The public AOS CLI owns
runtime startup and authentication; tool execution remains scoped to this
principal and enforced by the Astrid engine broker.

Workspace and principal-home Skills can extend this host after the plugin was
published. When list_skills is available, inspect dir_path \"skills\" and load
relevant entries with read_skill. Capsules may serve detailed guidance through
ordinary IPC tools."
exit 0
