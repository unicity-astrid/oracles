#!/usr/bin/env sh
# Host thin wrapper → plugins/common/bin/astrid-doctor
set -eu
HERE=$(CDPATH= cd -- "$(dirname "$0")" 2>/dev/null && pwd -P) || HERE=$(dirname "$0")
# Prefer host-specific root vars, fall back to common resolution inside the script.
export ASTRID_PLUGIN_ROOT="${ASTRID_PLUGIN_ROOT:-${CLAUDE_PLUGIN_ROOT:-$HERE/..}}"
# shellcheck disable=SC1091
# Make CLAUDE_PLUGIN_ROOT / GROK_PLUGIN_ROOT also point at this plugin for legacy lines.
export CLAUDE_PLUGIN_ROOT="${CLAUDE_PLUGIN_ROOT:-$ASTRID_PLUGIN_ROOT}"
COMMON="$HERE/../../common/bin/astrid-doctor"
if [ ! -x "$COMMON" ]; then
  COMMON="$HERE/../../common/bin/astrid-doctor"
fi
# Resolve absolute common path from monorepo layout: plugins/<host>/bin → plugins/common/bin
COMMON=$(CDPATH= cd -- "$HERE/../../common/bin" 2>/dev/null && pwd -P)/astrid-doctor
exec "$COMMON" "$@"
