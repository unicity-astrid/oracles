#!/usr/bin/env sh
# Ensure an Astrid daemon is up, then become the MCP stdio server for this
# Grok Build session.
#
# Bundled with the Astrid Grok Build plugin so installing the plugin needs
# no separate `astrid start` — the daemon comes up the first time Grok
# Code launches the MCP server, and tears itself down when the editor exits.
# A plugin cannot spawn a long-lived host daemon directly; this wrapper
# closes that gap from inside the plugin.
#
# DAEMON LIFECYCLE: we boot the daemon in EPHEMERAL mode (`astrid-daemon
# --ephemeral`), which auto-shuts-down ~30s after its last client
# disconnects. This session's `mcp serve` uplink is that client, so the
# daemon lives exactly as long as the editor (plus the grace window) and
# self-cleans afterwards — no orphaned background process. We deliberately
# do NOT use `astrid start`, which forces PERSISTENT mode (stays up until
# `astrid stop`). If a daemon is already running (persistent or ephemeral,
# e.g. a second concurrent Grok session, or one you started by hand) we
# reuse it untouched — but ONLY when it is the same binary we resolved.
# A mismatched binary (Homebrew daemon vs worktree debug CLI) fails closed
# with a clear recovery path.
#
# BINARY RESOLUTION: shared with the doctor and HUD via lib-astrid-resolve.sh.
# Prefers ASTRID_BIN{,_ROOT} / .mcp.json / a nearby core/target/{debug,release}
# pair over PATH/Homebrew, so dev worktrees are not silently pinned to a stale
# release install. Ported from the Sibyl (Codex) plugin.
#
# stdout DISCIPLINE: the MCP transport owns stdout — only the JSON-RPC
# stream produced by `astrid mcp serve` may go there. Everything this
# wrapper emits goes to stderr, and the daemon-start output is silenced, so
# a stray line can never corrupt the protocol framing.
set -eu

log() { printf 'astrid-up: %s\n' "$*" >&2; }

# Plugin root = parent of this script's directory (bin/ → plugin/).
ASTRID_PLUGIN_ROOT="$(CDPATH= cd -- "$(dirname "$0")/.." 2>/dev/null && pwd -P)" \
  || ASTRID_PLUGIN_ROOT="$(dirname "$(dirname "$0")")"
# shellcheck source=lib-astrid-resolve.sh
. "$ASTRID_PLUGIN_ROOT/bin/lib-astrid-resolve.sh"

if ! astrid_resolve_apply; then
  # Astrid isn't installed / not buildable from this tree. We deliberately do
  # NOT install it from here: this process IS the MCP stdio server (no TTY,
  # stdout is the JSON-RPC transport), so prompting for consent is impossible
  # and a long install would wedge MCP startup or corrupt the protocol framing.
  # Point at the explicit bootstrapper instead — the SessionStart doctor
  # surfaces the same, so Grok can offer to run it in-conversation.
  INSTALLER="$ASTRID_PLUGIN_ROOT/bin/astrid-install"
  log "could not find an executable astrid + astrid-daemon pair."
  log "looked for ASTRID_BIN/ASTRID_DAEMON, ASTRID_BIN_ROOT, .mcp.json ASTRID_BIN_ROOT,"
  log "nearby core/target/{debug,release}, ~/.astrid/bin, Homebrew, and PATH."
  if [ -x "$INSTALLER" ]; then
    log "install a release with this plugin's bootstrapper, then start a new session:"
    log "    $INSTALLER"
    log "  (or: brew install unicity-astrid/tap/astrid)"
    log "for a worktree debug build: cargo build -p astrid-cli -p astrid-daemon"
    log "  then set ASTRID_BIN_ROOT=<repo>/core/target/debug (or re-launch from that tree)."
  else
    log "install it (brew install unicity-astrid/tap/astrid), then start a new session."
  fi
  exit 127
fi

if [ "${ASTRID_SOURCE:-}" = "dev" ] || [ "${ASTRID_SOURCE:-}" = "bin-root" ] \
  || [ "${ASTRID_SOURCE:-}" = "mcp-config" ] || [ "${ASTRID_SOURCE:-}" = "direct" ]; then
  log "using Astrid from ${ASTRID_SOURCE}: $ASTRID"
fi

# The readiness sentinel the daemon writes once every capsule is loaded and
# the accept loop is live. Mirrors astrid-core::dirs (run/system.ready under
# ASTRID_HOME, default ~/.astrid).
ASTRID_HOME_DIR="${ASTRID_HOME:-$HOME/.astrid}"
READY="$ASTRID_HOME_DIR/run/system.ready"
SOCK="$ASTRID_HOME_DIR/run/system.sock"
PID_FILE="$ASTRID_HOME_DIR/run/system.pid"

# Liveness probe. `astrid status` exits 0 whether the daemon is up OR down
# (it just prints a human line), so the exit code is useless here — we match
# the live-status line instead, which is emitted ONLY after a successful
# round-trip to a running daemon. A false negative is self-healing: the
# redundant boot below fails to bind the in-use socket and exits harmlessly,
# and `mcp serve` connects to the daemon that is already up.
daemon_live() { "$ASTRID" status 2>/dev/null | grep -q '(PID'; }

canonical_path() {
  path="$1"
  if command -v realpath >/dev/null 2>&1; then
    realpath "$path" 2>/dev/null && return 0
  fi
  dir="$(dirname "$path")"
  base="$(basename "$path")"
  (CDPATH= cd -- "$dir" >/dev/null 2>&1 && printf '%s/%s\n' "$(pwd -P)" "$base") \
    || printf '%s\n' "$path"
}

# system.pid format: line 1 = pid, line 2 = absolute path of the running daemon.
daemon_pid_binary() {
  sed -n '2p' "$PID_FILE" 2>/dev/null || true
}

daemon_pid_live() {
  [ -f "$PID_FILE" ] || return 1
  pid="$(sed -n '1p' "$PID_FILE" 2>/dev/null | sed 's/[^0-9].*$//')"
  [ -n "$pid" ] || return 1
  kill -0 "$pid" 2>/dev/null
}

daemon_matches_selected_binary() {
  running="$(daemon_pid_binary)"
  # Older daemons may not write the binary path; skip the check rather than
  # false-positive a mismatch.
  [ -n "$running" ] || return 0
  [ "$(canonical_path "$running")" = "$(canonical_path "$ASTRID_DAEMON")" ]
}

ensure_daemon_binary_matches() {
  if daemon_matches_selected_binary; then
    return 0
  fi
  log "Astrid daemon is already running from a different binary:"
  log "  running:  $(daemon_pid_binary)"
  log "  selected: $ASTRID_DAEMON"
  log "stop the running daemon (\`astrid stop\` / kill the PID), then reconnect the MCP server."
  exit 1
}

clear_stale_daemon_run_files() {
  rm -f "$SOCK" "$PID_FILE" "$READY" \
    "$ASTRID_HOME_DIR/run/system.token" 2>/dev/null || true
}

ensure_daemon_ready() {
  # Reuse a live daemon only when it matches the resolved binary. Otherwise
  # refuse — mixing a Homebrew daemon with a worktree CLI (or vice versa) is
  # how MCP handshakes die mid-initialize with opaque connection-closed errors.
  if daemon_pid_live; then
    ensure_daemon_binary_matches
    i=0
    while [ "$i" -lt 80 ]; do
      if [ -S "$SOCK" ] && [ -e "$READY" ]; then
        # Prefer the status round-trip when cheap, but markers alone are enough
        # to proceed into mcp serve (serve has its own handshake).
        return 0
      fi
      sleep 0.25 2>/dev/null || sleep 1
      i=$((i + 1))
    done
    log "daemon process exists but readiness markers are incomplete; not starting a second daemon."
    log "recover the existing daemon (or \`astrid stop\`), then reconnect the MCP server."
    exit 1
  fi

  # Stale sock/pid/ready from a dead process: clear before boot so we don't
  # attach to a ghost socket or refuse to bind.
  if [ -S "$SOCK" ] || [ -f "$PID_FILE" ] || [ -e "$READY" ]; then
    log "clearing stale Astrid daemon run files before startup..."
    clear_stale_daemon_run_files
  fi

  if [ ! -x "$ASTRID_DAEMON" ]; then
    log "no daemon running and cannot find 'astrid-daemon' to boot one (resolved CLI: $ASTRID)."
    log "start one yourself with: astrid start"
    exit 127
  fi

  log "no daemon running — booting one (ephemeral, self-cleaning) from $ASTRID_DAEMON..."
  # Detach via a subshell that exits immediately, so the daemon reparents to
  # init right away and outlives this wrapper (and the `mcp serve` it execs
  # into) — exactly how the CLI's own spawn_daemon detaches it. No controlling
  # stdio; both streams silenced so nothing can reach the MCP stdout stream.
  ( "$ASTRID_DAEMON" --ephemeral </dev/null >/dev/null 2>&1 & )

  # Wait for the daemon to become ready. Budget ~22s: comfortably under Grok
  # Code's hard MCP-connect abort (measured in the MCP log at 30s after this
  # server process is spawned), but long enough to ride out a COLD first boot,
  # where wasmtime compiles a freshly installed distro's capsules and readiness
  # runs well past the old ~10s budget. That cold-first-run case is exactly when
  # a new user's very first governed session would otherwise come up toolless
  # (fresh install + first launch is the guaranteed cold-compile path).
  #
  # The sleep is guarded the same way the original loop guarded it -- a
  # strict/busybox `sleep` that rejects fractional seconds must not abort the
  # script under `set -e`. But it must ALSO not silently stretch the budget: 440
  # whole-second sleeps would be ~440s and blow far past the connect deadline.
  # So probe fractional-sleep support ONCE (same `sleep 0.05 2>/dev/null` test
  # the original used per-iteration) and pick a cadence that lands on ~22s worst
  # case either way, deriving the ~5s progress heartbeat from the same probe:
  #   fractional sleep (50ms): 440 iterations x 0.05s = ~22s, heartbeat every 100
  #   strict sleep (1s only):   22 iterations x 1s    = ~22s, heartbeat every 5
  if sleep 0.05 2>/dev/null; then
    poll_max=440
    progress_every=100                          # 100 x 50ms = ~5s
    poll_sleep() { sleep 0.05 2>/dev/null || sleep 1; }
  else
    poll_max=22
    progress_every=5                            # 5 x 1s = ~5s
    poll_sleep() { sleep 1; }
  fi

  i=0
  while [ "$i" -lt "$poll_max" ]; do
    if daemon_pid_live && [ -e "$READY" ] && [ -S "$SOCK" ]; then
      ensure_daemon_binary_matches
      break
    fi
    # Heartbeat every ~5s so the MCP log shows the boot is progressing, not
    # hung, during a long cold compile. To STDERR only -- stdout is the JSON-RPC
    # transport. Skipped at i=0 (nothing has elapsed yet); the readiness check
    # above already broke out if we became ready before the first heartbeat.
    if [ "$i" -gt 0 ] && [ "$((i % progress_every))" -eq 0 ]; then
      log "daemon still booting (first boot compiles capsules, this can take a while)..."
    fi
    poll_sleep
    i=$((i + 1))
  done

  if ! daemon_pid_live || [ ! -e "$READY" ]; then
    # Expiry. We deliberately do NOT best-effort `exec astrid mcp serve` here and
    # let its uplink connect ride out a late boot. VERIFIED read-only against the
    # shipped CLI (astrid-cli `mcp serve` -> astrid-uplink `SocketClient::connect`):
    # the serve entrypoint does a one-shot socket existence check plus a single
    # `UnixStream::connect` plus a single handshake, with NO retry, backoff, or
    # wait. Against a still-booting daemon the socket is either absent or refusing
    # (the cli capsule owns the listener and has not bound it yet), so `mcp serve`
    # would fail fast non-zero and close the transport -- no better than exiting,
    # and it would bury the actionable guidance below. So on expiry we exit and
    # tell the user exactly how to recover.
    #
    # Crucially, the detached daemon KEEPS booting after we exit -- it reparented
    # to init and is not tied to this wrapper's lifetime -- so this is NOT "the
    # daemon failed", it is "the daemon isn't ready YET". Say that plainly.
    log "the Astrid daemon is still starting in the background -- a cold first"
    log "boot compiles capsules and can take a while. It was not ready within the"
    log "~22s budget (kept under Grok Build's MCP connect deadline), so this"
    log "connection attempt is being closed. The daemon itself is NOT broken and"
    log "is very likely to finish booting momentarily."
    log ""
    log "To connect: wait ~30 seconds, then in Grok Build run /mcp and reconnect"
    log "the 'astrid' server -- a warm daemon attaches instantly."
    log "If it still fails after that, check the logs under $ASTRID_HOME_DIR/log."
    exit 1
  fi
}

ensure_daemon_ready

# Resolve the principal this session will act as. Grok Build expands the
# `${user_config.principal}` arg from .mcp.json: a configured value arrives as
# `--principal <name>`; a blank one (operator cleared it) collapses to a lone
# `--principal` with no value.
# A cleared principal defaults to this least-authority family identity (see the
# blank-principal handling below), NOT the admin `default`.
LEAST_AUTHORITY_PRINCIPAL="grok-code"
PRINCIPAL=""
[ "${1:-}" = "--principal" ] && PRINCIPAL="${2:-}"

# Blank principal: the operator cleared `${user_config.principal}`, which Grok
# Code collapses to a lone `--principal` with no value. Do NOT fall through to
# `astrid mcp serve`'s bare resolution (context::resolve_agent → active agent
# context, else `default`): `default` is the ADMIN bootstrap identity, so a
# cleared principal would silently serve the governed Grok with admin
# authority — a privilege footgun. Default a cleared principal to the
# least-authority family identity instead, and re-inject it as an explicit
# `--principal` so the provisioning + exec below act as it; an operator who
# deliberately wants admin passes `--principal default`. (Grok Build DROPS the
# empty value, so the server is invoked as `astrid-up --principal` (one arg),
# not `--principal ""` (two); a blind `shift 2` would over-shift and abort under
# `set -eu`.)
if [ "${1:-}" = "--principal" ] && [ -z "$PRINCIPAL" ]; then
  shift
  [ "$#" -gt 0 ] && shift
  PRINCIPAL="$LEAST_AUTHORITY_PRINCIPAL"
  set -- --principal "$PRINCIPAL" "$@"
fi

# Unexpanded plugin placeholder (some hosts leave the literal in place).
if [ "$PRINCIPAL" = '${user_config.principal}' ]; then
  PRINCIPAL="$LEAST_AUTHORITY_PRINCIPAL"
  set -- --principal "$PRINCIPAL"
fi

# Publish the resolved session principal for the read-only display surfaces
# (SessionStart doctor, HUD status line, /astrid:whoami) so they report the
# identity this session ACTS AS — not the operator's active CLI context, which
# stays `default`/admin and is intentionally decoupled. Co-located with the
# run-dir sentinels those scripts already resolve (a live daemon owns the dir).
# Best-effort: a write failure only degrades the displays to their CLI-context
# fallback, never the session itself.
SESSION_PRINCIPAL_FILE="$ASTRID_HOME_DIR/run/session.principal"
if [ -n "$PRINCIPAL" ]; then
  printf '%s\n' "$PRINCIPAL" > "$SESSION_PRINCIPAL_FILE" 2>/dev/null \
    || log "note: could not publish session principal to $SESSION_PRINCIPAL_FILE; HUD/doctor fall back to the CLI context."
else
  # Blank → `mcp serve` resolves the active context itself; clear any stale
  # value so the displays fall back to that same context, not a past session.
  # A missing file is the desired end state, so a failed remove is not a fault.
  rm -f "$SESSION_PRINCIPAL_FILE" 2>/dev/null || true
fi

# Provision the session principal as a SCOPED agent before serving as it, placed
# in the `grok` FAMILY group rather than the generic built-in `agent` tier.
# The `grok` group is a custom, operator-manageable group carrying the same
# self-scoped baseline the built-in `agent` group grants (`self:*`,
# `delegate:self:*`): self-service over the principal's OWN session/quota/KV plus
# recursive delegation, and NONE of the admin-meta surface the `default`
# principal holds via the `admin` group (`*`). So the governed Grok session can
# drive its own tools but cannot administer the OS it runs on — no system-wide
# capsule:install, no agent:* / group:* / caps:grant, no quota:set on other
# principals, no system:shutdown, no audit:read_all across principals. Grok
# runs as a least-authority agent, not as admin.
#
# Why a named `grok` group instead of the built-in `agent`: it is the Grok
# product FAMILY identity. Per-product principals (grok-code here; grok-chat,
# cowork later) share this one baseline and diverge via per-principal
# grants/revokes (precedence: revokes > grants > group). An operator can re-tune
# the whole family's authority in one place — `astrid group modify grok
# --add-caps ...` propagates live to every member on its next check — while the
# built-in `agent` tier stays the generic fallback for non-Grok agents.
#
#   group create grok --caps self:*,delegate:self:*   the family baseline
#   agent create <p> --group grok --yes               scoped principal in it
#   --yes                   non-interactive (no TTY in a plugin/MCP context)
#   --inherit-from default  copy the operator's env/KV/secrets so tool execution
#                           behaves identically, minus that authority. Landed
#                           after astrid 0.8.0; on an older CLI it is rejected and
#                           we fall back to the plain scoped create. The scoping
#                           (group `grok`) is identical either way — only the
#                           env/secret carry-over is version-gated.
#
# Idempotent + non-fatal, but NOT silent: a second run hits "already exists"
# (benign — expected on every launch after the first) and stays quiet; any OTHER
# failure (daemon unreachable, capability denied, …) is surfaced as a WARNING on
# stderr so a broken provision is visible, not swallowed. Still non-fatal:
# serving the session matters more than wedging on a provisioning hiccup, and an
# unprovisioned principal falls back to an empty profile (zero caps) — MORE
# restrictive, so the degradation fails secure on the cap axis. We never
# auto-create `default` — the reserved bootstrap admin identity (the kernel
# refuses to re-create it regardless) — so opting a session into it is a
# deliberate operator choice, not something this wrapper does.
#
# NOTE (hard floor): per-connection principal auth has LANDED. `agent create`
# mints a per-principal ed25519 keypair (keys/<p>.key in system custody + a
# registered public key on the profile) and `astrid mcp serve` signs the socket
# handshake challenge with it, so the daemon CRYPTOGRAPHICALLY binds this
# connection to PRINCIPAL. A connection that cannot sign is stamped the
# no-capability `anonymous` (fail-closed: a bad signature fails the handshake,
# never falls back to unauthenticated). The scoping below is therefore an
# enforced boundary, not just an honest default.
if [ -n "$PRINCIPAL" ] && [ "$PRINCIPAL" != "default" ]; then
  # Ensure the `grok` family group exists before placing the principal in it.
  # CREATE-IF-ABSENT, never reconcile: we only `group create` when `group show`
  # reports it missing, so an operator who later retunes the group
  # (`astrid group modify grok --add-caps/--remove-caps`) keeps that change —
  # a subsequent launch sees the group present and skips the create entirely.
  # Belt & suspenders: `group create` is create-only (the kernel rejects a
  # redundant create as "declares ... more than once"), so it can NEVER overwrite
  # existing caps even if the `group show` guard is lost to a race. Likewise the
  # `agent create` below no-ops on an existing principal, so an operator's group
  # reassignment of the principal also survives.
  if ! "$ASTRID" group show grok >/dev/null 2>&1; then
    if group_out="$("$ASTRID" group create grok \
        --caps "self:*,delegate:self:*" \
        --description "Grok product family — self-scoped baseline" 2>&1)"; then
      log "created the 'grok' capability group (self-scoped baseline)."
    else
      case "$group_out" in
        # Exists already, or a concurrent launch won the create between our
        # `group show` guard and here — both benign. The kernel reports a
        # redundant create as "declares ... more than once", not "exists".
        *"already exists"*|*"more than once"*) : ;;
        *)
          log "WARNING: could not create the 'grok' group:"
          log "  ${group_out:-<no output>}"
          log "  '$PRINCIPAL' may fall back to an unscoped profile." ;;
      esac
    fi
  fi

  log "ensuring scoped agent principal '$PRINCIPAL' exists (group 'grok')..."
  # Enriched form first (carries env/secrets, post-0.8.0); fall back to the plain
  # scoped create. Both place the principal in the `grok` group. Capture output
  # so a real failure can be reported.
  if create_out="$("$ASTRID" agent create "$PRINCIPAL" --group grok --inherit-from default --yes 2>&1)" \
     || create_out="$("$ASTRID" agent create "$PRINCIPAL" --group grok --yes 2>&1)"; then
    log "scoped principal '$PRINCIPAL' ready."
  else
    case "$create_out" in
      *"already exists"*)
        # The principal was provisioned earlier — the EXPECTED steady state. But
        # a principal created BEFORE per-connection auth landed is keyless, and
        # the shaped create above can NEVER heal it: any profile-shaping input
        # (`--group`, `--inherit-from`) makes `agent create` keep the hard
        # "already exists" error instead of backfilling. The kernel backfills a
        # missing keypair ONLY on a BARE re-create (no shaping inputs), so make
        # that bare call now. Idempotent + security-positive: a keyless upgrader
        # gains its keypair (moving from a `anonymous`-stamped connection to its
        # own scoped identity); an already-keyed principal just re-reports
        # "already exists" (benign — the steady state on every later launch).
        if heal_out="$("$ASTRID" agent create "$PRINCIPAL" --yes 2>&1)"; then
          log "backfilled the missing keypair for existing principal '$PRINCIPAL'."
        else
          case "$heal_out" in
            *"already exists"*) : ;; # already keyed — nothing to heal
            *)
              log "WARNING: keypair backfill for '$PRINCIPAL' did not complete:"
              log "  ${heal_out:-<no output>}"
              log "  the session may be stamped 'anonymous' until '$PRINCIPAL' has a keypair." ;;
          esac
        fi
        ;;
      *)
        log "WARNING: failed to provision scoped principal '$PRINCIPAL':"
        log "  ${create_out:-<no output>}"
        log "  serving anyway; the session may fall back to an unscoped profile." ;;
    esac
  fi
fi

exec "$ASTRID" mcp serve "$@"
