#!/bin/sh
set -eu

plugin_root() {
  script_dir="$(dirname "$0")"
  (cd "$script_dir/.." >/dev/null 2>&1 && pwd -P) || printf '%s\n' "$script_dir/.."
}

bin_pair_from_root() {
  root="$1"
  [ -x "$root/astrid" ] && [ -x "$root/astrid-daemon" ] || return 1
  printf '%s|%s\n' "$root/astrid" "$root/astrid-daemon"
}

mcp_config_bin_root() {
  config="$(plugin_root)/.mcp.json"
  [ -f "$config" ] || return 1
  sed -n 's/.*"ASTRID_BIN_ROOT"[[:space:]]*:[[:space:]]*"\([^"]*\)".*/\1/p' "$config" | sed -n '1p'
}

dev_bin_roots() {
  for base in "$(pwd -P 2>/dev/null || pwd)" "$(plugin_root)"; do
    dir="$base"
    while [ "$dir" != "/" ] && [ -n "$dir" ]; do
      printf '%s\n' "$dir/core/target/debug"
      printf '%s\n' "$dir/core/target/release"
      printf '%s\n' "$dir/target/debug"
      printf '%s\n' "$dir/target/release"
      dir="$(dirname "$dir")"
    done
  done
}

resolve_astrid_pair() {
  if [ -n "${ASTRID_BIN:-}" ] || [ -n "${ASTRID_DAEMON:-}" ]; then
    if [ -x "${ASTRID_BIN:-}" ] && [ -x "${ASTRID_DAEMON:-}" ]; then
      printf 'direct|%s|%s\n' "$ASTRID_BIN" "$ASTRID_DAEMON"
      return 0
    fi
    echo "astrid-up: ASTRID_BIN and ASTRID_DAEMON must both point to executable files" >&2
    return 127
  fi

  if [ -n "${ASTRID_BIN_ROOT:-}" ]; then
    pair="$(bin_pair_from_root "$ASTRID_BIN_ROOT")" || {
      echo "astrid-up: ASTRID_BIN_ROOT is set but does not contain executable astrid and astrid-daemon:" >&2
      echo "astrid-up:   $ASTRID_BIN_ROOT" >&2
      return 127
    }
    printf 'bin-root|%s\n' "$pair"
    return 0
  fi

  config_root="$(mcp_config_bin_root || true)"
  if [ -n "$config_root" ]; then
    pair="$(bin_pair_from_root "$config_root")" || {
      echo "astrid-up: .mcp.json ASTRID_BIN_ROOT does not contain executable astrid and astrid-daemon:" >&2
      echo "astrid-up:   $config_root" >&2
      return 127
    }
    printf 'mcp-config|%s\n' "$pair"
    return 0
  fi

  for root in $(dev_bin_roots); do
    if pair="$(bin_pair_from_root "$root")"; then
      printf 'dev|%s\n' "$pair"
      return 0
    fi
  done

  for root in \
    "${CARGO_HOME:-$HOME/.cargo}/bin" \
    "$HOME/.cargo/bin" \
    "$HOME/.astrid/bin" \
    /opt/homebrew/bin \
    /usr/local/bin; do
    if pair="$(bin_pair_from_root "$root")"; then
      printf 'installed|%s\n' "$pair"
      return 0
    fi
  done

  if command -v astrid >/dev/null 2>&1; then
    cli="$(command -v astrid)"
    daemon="$(dirname "$cli")/astrid-daemon"
    if [ -x "$daemon" ]; then
      printf 'path|%s|%s\n' "$cli" "$daemon"
      return 0
    fi
  fi

  echo "astrid-up: could not find executable astrid and astrid-daemon pair" >&2
  echo "astrid-up: set ASTRID_BIN_ROOT=/path/to/bin or install Astrid first" >&2
  return 127
}

astrid_pair="$(resolve_astrid_pair)" || exit $?
ASTRID_SOURCE="${astrid_pair%%|*}"
astrid_pair="${astrid_pair#*|}"
ASTRID="${astrid_pair%%|*}"
ASTRID_DAEMON="${astrid_pair#*|}"

ensure_principal() {
  principal_id="${ASTRID_PRINCIPAL_ID:-codex-code}"
  lock_principal="$(topic_segment "$principal_id")"
  if [ -z "$lock_principal" ]; then
    lock_principal="codex-code"
  fi
  lock_dir="${TMPDIR:-/tmp}/astrid-codex-principal.${lock_principal}.lock"
  tries=0
  while ! mkdir "$lock_dir" 2>/dev/null; do
    tries=$((tries + 1))
    if [ "$tries" -ge 50 ]; then
      break
    fi
    sleep 0.1
  done
  if [ -d "$lock_dir" ]; then
    trap 'rmdir "$lock_dir" 2>/dev/null || true' EXIT HUP INT TERM
  fi

  ensure_daemon_ready

  provision_mcp_principal "$principal_id"
}

new_session_id() {
  if [ -n "${ASTRID_SESSION_ID:-}" ]; then
    topic_segment "$ASTRID_SESSION_ID"
    return
  fi
  if command -v uuidgen >/dev/null 2>&1; then
    topic_segment "codex-$(uuidgen)"
    return
  fi
  topic_segment "codex-$(date +%s)-$$"
}

mint_hook_token() {
  if [ -n "${ASTRID_HOOK_TOKEN:-}" ]; then
    printf '%s' "$ASTRID_HOOK_TOKEN"
    return
  fi
  if command -v openssl >/dev/null 2>&1; then
    openssl rand -hex 32 2>/dev/null && return
  fi
  if command -v uuidgen >/dev/null 2>&1; then
    uuidgen | tr -d '-'
    return
  fi
  printf '%s' "$(date +%s)-$$"
}

launch_codex() {
  if ! command -v codex >/dev/null 2>&1; then
    echo "codex CLI not found on PATH" >&2
    exit 127
  fi
  ensure_principal
  principal_id="${ASTRID_PRINCIPAL_ID:-codex-code}"
  session_id="$(new_session_id)"
  workspace_id="$(derive_workspace_id)"
  hook_token="$(mint_hook_token)"

  export ASTRID_PRINCIPAL_ID="$principal_id"
  export ASTRID_SESSION_ID="$session_id"
  export ASTRID_WORKSPACE_ID="$workspace_id"
  export ASTRID_HOOK_TOKEN="$hook_token"

  profile="${CODEX_PROFILE:-codex}"
  exec codex --profile "$profile" "$@"
}

launch_codex_exec() {
  if ! command -v codex >/dev/null 2>&1; then
    echo "codex CLI not found on PATH" >&2
    exit 127
  fi
  ensure_principal
  principal_id="${ASTRID_PRINCIPAL_ID:-codex-code}"
  session_id="$(new_session_id)"
  workspace_id="$(derive_workspace_id)"
  hook_token="$(mint_hook_token)"

  export ASTRID_PRINCIPAL_ID="$principal_id"
  export ASTRID_SESSION_ID="$session_id"
  export ASTRID_WORKSPACE_ID="$workspace_id"
  export ASTRID_HOOK_TOKEN="$hook_token"

  profile="${CODEX_PROFILE:-codex}"
  exec codex exec --profile "$profile" --json "$@"
}

emit_hook() {
  event="$(topic_segment "${1:-}")"
  if [ -z "$event" ]; then
    echo "usage: astrid-up codex hook <event>" >&2
    exit 2
  fi

  tmp="${TMPDIR:-/tmp}/astrid-codex-hook.$$.$event.json"
  trap 'rm -f "$tmp"' EXIT HUP INT TERM
  cat >"$tmp" || true

  ensure_principal || {
    if [ "${ASTRID_SIBYL_HOOK_FAIL_CLOSED:-${ASTRID_CODEX_HOOK_FAIL_CLOSED:-0}}" = "1" ]; then
      exit 1
    fi
    exit 0
  }

  session_id="$(derive_session_id "$tmp")"
  workspace_id="$(derive_workspace_id)"
  token="${ASTRID_HOOK_TOKEN:-}"
  payload_b64="$(base64_file "$tmp")"
  cwd_b64="$(pwd | base64_stream)"
  pid="$$"
  ppid="${PPID:-0}"
  topic="codex.v1.hook.$session_id.$event"

  workspace_json="null"
  if [ -n "$workspace_id" ]; then
    workspace_json="\"$workspace_id\""
  fi

  envelope="$(printf '{"schema_version":1,"principal_id":"%s","session_id":"%s","event":"%s","workspace_id":%s,"pid":%s,"ppid":%s,"payload_b64":"%s","cwd_b64":"%s","token":"%s","transport":"codex-plugin"}' \
    "$(json_id "${ASTRID_PRINCIPAL_ID:-codex-code}")" \
    "$session_id" \
    "$event" \
    "$workspace_json" \
    "$pid" \
    "$ppid" \
    "$payload_b64" \
    "$cwd_b64" \
    "$(json_id "$token")")"

  if "$ASTRID" emit --help >/dev/null 2>&1; then
    if [ "${ASTRID_SIBYL_HOOK_FAIL_CLOSED:-${ASTRID_CODEX_HOOK_FAIL_CLOSED:-0}}" = "1" ]; then
      printf '%s' "$envelope" | "$ASTRID" emit --topic "$topic" --stdin
      return $?
    fi
    printf '%s' "$envelope" | "$ASTRID" emit --topic "$topic" --stdin >/dev/null 2>&1 || true
    return 0
  fi

  # Older Astrid CLIs do not have the native event emitter yet. Do not block
  # Codex startup/tooling before the host shim lands.
  return 0
}

derive_session_id() {
  payload_file="$1"
  if [ -n "${ASTRID_SESSION_ID:-}" ]; then
    sid="$(topic_segment "$ASTRID_SESSION_ID")"
    if [ -n "$sid" ]; then
      printf '%s' "$sid"
      return
    fi
  fi
  if command -v jq >/dev/null 2>&1; then
    from_payload="$(jq -r '.session_id // .thread_id // .threadId // .conversation_id // .conversationId // empty' "$payload_file" 2>/dev/null || true)"
    if [ -n "$from_payload" ]; then
      sid="$(topic_segment "codex-$from_payload")"
      if [ -n "$sid" ]; then
        printf '%s' "$sid"
        return
      fi
    fi
  fi
  codex_pid="$(parent_codex_pid)"
  topic_segment "codex-pid-$codex_pid"
}

derive_workspace_id() {
  if [ -n "${ASTRID_WORKSPACE_ID:-}" ]; then
    topic_segment "$ASTRID_WORKSPACE_ID"
    return
  fi
  if command -v cksum >/dev/null 2>&1; then
    hash="$(pwd | cksum | sed 's/ .*//')"
    topic_segment "cwd-$hash"
    return
  fi
  printf '%s' "cwd"
}

parent_codex_pid() {
  hook_parent="${PPID:-$$}"
  grandparent="$(ps -o ppid= -p "$hook_parent" 2>/dev/null | tr -d ' ' || true)"
  if [ -n "$grandparent" ]; then
    printf '%s' "$grandparent"
  else
    printf '%s' "$hook_parent"
  fi
}

topic_segment() {
  printf '%s' "$1" | sed 's/[^A-Za-z0-9_-]/-/g; s/--*/-/g; s/^-//; s/-$//'
}

json_id() {
  printf '%s' "$1" | sed 's/[^A-Za-z0-9._:-]/-/g'
}

base64_file() {
  base64 <"$1" | tr -d '\n'
}

base64_stream() {
  base64 | tr -d '\n'
}

mcp_serve() {
  principal_id=""
  if [ "${1:-}" = "--principal" ]; then
    shift
    principal_id="${1:-}"
    if [ "$#" -gt 0 ]; then
      shift
    fi
  fi

  case "$principal_id" in
    ""|'${user_config.principal}')
      principal_id="${ASTRID_PRINCIPAL_ID:-codex-code}"
      ;;
  esac

  if [ -z "$(topic_segment "$principal_id")" ]; then
    principal_id="codex-code"
  fi

  ensure_daemon_ready
  publish_session_principal "$principal_id"
  provision_mcp_principal "$principal_id"
  exec "$ASTRID" mcp serve --principal "$principal_id" "$@"
}

daemon_live() {
  "$ASTRID" status 2>/dev/null | grep -q '(PID'
}

canonical_path() {
  path="$1"
  if command -v realpath >/dev/null 2>&1; then
    realpath "$path" 2>/dev/null && return 0
  fi
  dir="$(dirname "$path")"
  base="$(basename "$path")"
  (cd "$dir" >/dev/null 2>&1 && printf '%s/%s\n' "$(pwd -P)" "$base") || printf '%s\n' "$path"
}

daemon_pid_binary() {
  astrid_home="${ASTRID_HOME:-$HOME/.astrid}"
  sed -n '2p' "$astrid_home/run/system.pid" 2>/dev/null || true
}

daemon_matches_selected_binary() {
  running="$(daemon_pid_binary)"
  if [ -z "$running" ]; then
    return 0
  fi
  [ "$(canonical_path "$running")" = "$(canonical_path "$ASTRID_DAEMON")" ]
}

ensure_daemon_binary_matches() {
  if daemon_matches_selected_binary; then
    return 0
  fi
  echo "astrid-up: Astrid daemon is already running from a different binary:" >&2
  echo "astrid-up:   running:  $(daemon_pid_binary)" >&2
  echo "astrid-up:   selected: $ASTRID_DAEMON" >&2
  echo "astrid-up: stop the running daemon, then reconnect the MCP server" >&2
  exit 1
}

daemon_pid_live() {
  astrid_home="${ASTRID_HOME:-$HOME/.astrid}"
  pid_file="$astrid_home/run/system.pid"
  if [ ! -f "$pid_file" ]; then
    return 1
  fi
  pid="$(sed -n '1p' "$pid_file" 2>/dev/null | sed 's/[^0-9].*$//')"
  if [ -z "$pid" ]; then
    return 1
  fi
  kill -0 "$pid" 2>/dev/null
}

daemon_markers_ready() {
  astrid_home="${ASTRID_HOME:-$HOME/.astrid}"
  [ -S "$astrid_home/run/system.sock" ] && [ -e "$astrid_home/run/system.ready" ]
}

clear_stale_daemon_run_files() {
  astrid_home="${ASTRID_HOME:-$HOME/.astrid}"
  run_dir="$astrid_home/run"
  rm -f "$run_dir/system.sock" \
    "$run_dir/system.pid" \
    "$run_dir/system.ready" \
    "$run_dir/system.token" 2>/dev/null || true
}

ensure_daemon_ready() {
  astrid_home="${ASTRID_HOME:-$HOME/.astrid}"
  socket="$astrid_home/run/system.sock"
  if daemon_pid_live; then
    ensure_daemon_binary_matches
    i=0
    while [ "$i" -lt 80 ]; do
      if daemon_markers_ready; then
        return 0
      fi
      sleep 0.25 2>/dev/null || sleep 1
      i=$((i + 1))
    done

    echo "astrid-up: Astrid daemon process exists but readiness markers are incomplete; not starting a second daemon" >&2
    echo "astrid-up: recover the existing daemon, then reconnect the MCP server" >&2
    exit 1
  fi
  if [ -S "$socket" ] || [ -f "$astrid_home/run/system.pid" ] || [ -f "$astrid_home/run/system.ready" ]; then
    echo "astrid-up: clearing stale Astrid daemon run files before startup" >&2
    clear_stale_daemon_run_files
  fi

  daemon="$ASTRID_DAEMON"
  if [ -z "$daemon" ] || [ ! -x "$daemon" ]; then
    echo "astrid-up: no daemon running and astrid-daemon was not found" >&2
    echo "astrid-up: start one with: astrid start" >&2
    exit 127
  fi

  ready="$astrid_home/run/system.ready"
  ( "$daemon" --ephemeral </dev/null >/dev/null 2>&1 & )

  if sleep 0.05 2>/dev/null; then
    poll_max=440
    poll_sleep() { sleep 0.05 2>/dev/null || sleep 1; }
  else
    poll_max=22
    poll_sleep() { sleep 1; }
  fi

  i=0
  while [ "$i" -lt "$poll_max" ]; do
    if daemon_pid_live && [ -e "$ready" ] && [ -S "$socket" ]; then
      ensure_daemon_binary_matches
      return 0
    fi
    poll_sleep
    i=$((i + 1))
  done

  echo "astrid-up: Astrid daemon is still starting; reconnect the MCP server shortly" >&2
  exit 1
}

publish_session_principal() {
  principal_id="$1"
  astrid_home="${ASTRID_HOME:-$HOME/.astrid}"
  session_principal_file="$astrid_home/run/session.principal"
  printf '%s\n' "$principal_id" >"$session_principal_file" 2>/dev/null || true
}

provision_mcp_principal() {
  principal_id="$1"
  if [ "$principal_id" = "default" ]; then
    return 0
  fi

  if local_codex_principal_ready "$principal_id" \
    && local_codex_capsules_ready "$principal_id"; then
    return 0
  fi

  group_show_out="$("$ASTRID" group show codex 2>&1)" || case "$group_show_out" in
    *"timed out"*|*"connection lost"*)
      echo "astrid-up: WARNING: could not confirm the 'codex' group because Astrid admin did not respond:" >&2
      echo "astrid-up:   ${group_show_out:-<no output>}" >&2
      ;;
    *)
    group_out="$("$ASTRID" group create codex \
      --caps "self:*,delegate:self:*" \
      --description "Astrid product family - self-scoped baseline" 2>&1)" || {
      case "$group_out" in
        *"already exists"*|*"more than once"*) : ;;
        *)
          echo "astrid-up: WARNING: could not create the 'codex' group:" >&2
          echo "astrid-up:   ${group_out:-<no output>}" >&2
          ;;
      esac
    }
      ;;
  esac

  agent_show_out="$("$ASTRID" agent show "$principal_id" 2>&1)" || case "$agent_show_out" in
    *"timed out"*|*"connection lost"*)
      echo "astrid-up: WARNING: could not confirm principal '$principal_id' because Astrid admin did not respond:" >&2
      echo "astrid-up:   ${agent_show_out:-<no output>}" >&2
      ;;
    *)
      create_out="$("$ASTRID" agent create "$principal_id" --group codex --inherit-from default --yes 2>&1)" \
        || create_out="$("$ASTRID" agent create "$principal_id" --group codex --yes 2>&1)" \
        || {
          case "$create_out" in
            *"already exists"*)
              heal_out="$("$ASTRID" agent create "$principal_id" --yes 2>&1)" || {
                case "$heal_out" in
                  *"already exists"*) : ;;
                  *)
                    echo "astrid-up: WARNING: keypair backfill for '$principal_id' did not complete:" >&2
                    echo "astrid-up:   ${heal_out:-<no output>}" >&2
                    ;;
                esac
              }
              ;;
            *)
              echo "astrid-up: WARNING: failed to provision scoped principal '$principal_id':" >&2
              echo "astrid-up:   ${create_out:-<no output>}" >&2
              ;;
          esac
        }
      ;;
  esac

  provision_codex_capsules "$principal_id"
}

codex_bundle_capsules() {
  printf '%s\n' \
    codex \
    codex-mcp \
    codex-install \
    astrid-capsule-a2a \
    astrid-capsule-cron \
    astrid-capsule-forge \
    astrid-capsule-herald \
    astrid-capsule-orient \
    astrid-capsule-system
}

local_codex_principal_ready() {
  principal_id="$1"
  astrid_home="${ASTRID_HOME:-$HOME/.astrid}"
  [ -f "$astrid_home/keys/$principal_id.key" ] \
    && [ -f "$astrid_home/etc/profiles/$principal_id.toml" ] \
    && [ -d "$astrid_home/home/$principal_id" ]
}

local_codex_capsules_ready() {
  principal_id="$1"
  astrid_home="${ASTRID_HOME:-$HOME/.astrid}"
  for capsule in $(codex_bundle_capsules); do
    [ -f "$astrid_home/home/$principal_id/.local/capsules/$capsule/meta.json" ] || return 1
  done
  return 0
}

codex_mcp_live() {
  case "$("$ASTRID" status 2>/dev/null || true)" in
    *" - codex-mcp"*) return 0 ;;
    *) return 1 ;;
  esac
}

wait_for_codex_mcp_live() {
  i=0
  while [ "$i" -lt 80 ]; do
    if codex_mcp_live; then
      return 0
    fi
    sleep 0.25 2>/dev/null || sleep 1
    i=$((i + 1))
  done
  return 1
}

provision_codex_capsules() {
  principal_id="$1"
  if [ "$principal_id" = "default" ]; then
    return 0
  fi

  root="$(plugin_root)"
  dist_dir="$root/dist"
  if [ ! -d "$dist_dir" ]; then
    dist_dir="$root/../dist"
  fi
  if [ ! -d "$dist_dir" ]; then
    echo "astrid-up: WARNING: Astrid capsule artifacts not found at '$dist_dir'; '$principal_id' may have no Astrid tools." >&2
    return 0
  fi

  reload_pending=0
  live_capsules="$("$ASTRID" status 2>/dev/null || true)"

  for capsule in $(codex_bundle_capsules); do
    artifact="$dist_dir/$capsule.capsule"
    if [ ! -f "$artifact" ]; then
      echo "astrid-up: WARNING: missing bundled capsule artifact '$artifact'; skipping." >&2
      continue
    fi

    if "$ASTRID" capsule show "$capsule" --agent "$principal_id" >/dev/null 2>&1; then
      if [ -z "$live_capsules" ]; then
        continue
      fi
      case "$live_capsules" in
        *" - $capsule"*) continue ;;
      esac
    fi

    install_out="$("$ASTRID" capsule install "$artifact" --principal "$principal_id" </dev/null 2>&1)" || {
      echo "astrid-up: WARNING: failed to install '$capsule' for '$principal_id':" >&2
      echo "astrid-up:   ${install_out:-<no output>}" >&2
      continue
    }

    case "$install_out" in
      *"will load on the next daemon start"*|*"didn't confirm a live reload"*|*"declined a live reload"*)
        reload_pending=1
        ;;
    esac
  done

  if [ "$reload_pending" = "1" ]; then
    echo "astrid-up: WARNING: one or more Astrid tool capsules were installed to disk but are not live yet." >&2
    echo "astrid-up: WARNING: restart Astrid with 'astrid restart', then reconnect the Codex MCP server." >&2
  fi
}

if [ "${1:-}" = "codex" ] || [ "${1:-}" = "codex" ]; then
  shift
  case "${1:-}" in
    ensure-principal)
      ensure_principal
      exit 0
      ;;
    up|repl)
      shift
      launch_codex "$@"
      ;;
    exec)
      shift
      launch_codex_exec "$@"
      ;;
    session-start)
      shift
      emit_hook "session_start"
      exit 0
      ;;
    hook)
      shift
      event="${1:-}"
      if [ -z "$event" ]; then
        echo "usage: astrid-up codex hook <event>" >&2
        exit 2
      fi

      emit_hook "$event"
      exit 0
      ;;
  esac
fi

if [ "${1:-}" = "--principal" ]; then
  mcp_serve "$@"
fi

if [ "${1:-}" = "mcp" ] && [ "${2:-}" = "serve" ]; then
  shift
  shift
  set -- --principal "${ASTRID_PRINCIPAL_ID:-codex-code}" "$@"
  mcp_serve "$@"
fi

if [ "${1:-}" = "mcp" ]; then
  exec "$ASTRID" "$@"
fi

exec "$ASTRID" "$@"
